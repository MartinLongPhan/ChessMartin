{
    "manifest_version": 3,
    "name": "MartinChessVN",
    "version": "2.0",
    "description": "UI Enhancer for Chess.com - Larger Clock, Insights HUD & Analysis.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://www.chess.com/*",
        "https://api.chess.com/*" 
    ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "assets/happy-face.png"
            ],
            "matches": [
                "*://www.chess.com/*"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
    {
        "matches": ["https://www.chess.com/*"],
        "js": ["early-init.js"],
        "run_at": "document_start"
    },
    {
        "matches": ["https://www.chess.com/*"],
        "js": [
            "assets/chess.min.js",
            "content.js"
        ],
        "run_at": "document_idle"
    }
    ]
}